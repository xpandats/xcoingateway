# XCoinGateway — Production Nginx Configuration
# Mainnet Requirement #8: TLS 1.2+ enforcement, WAF headers, rate limiting
#
# SETUP:
#   1. Copy to /etc/nginx/sites-available/xcoingateway
#   2. ln -s /etc/nginx/sites-available/xcoingateway /etc/nginx/sites-enabled/
#   3. Replace YOUR_DOMAIN with your actual domain
#   4. Install SSL cert: certbot --nginx -d YOUR_DOMAIN
#   5. nginx -t && systemctl reload nginx
#
# TLS CERT: Use Let's Encrypt (free) or paid cert for production
#   certbot --nginx -d api.xcoingateway.com

upstream xcg_api {
    server 127.0.0.1:3000;
    keepalive 32;
}

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN;

    # ACME challenge for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # All other HTTP → redirect to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# ── HTTPS API Server ──────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN;

    # ── TLS Configuration ──────────────────────────────────────────────────────
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    # PCI-DSS: TLS 1.2 MINIMUM. TLS 1.0 and 1.1 are prohibited.
    ssl_protocols TLSv1.2 TLSv1.3;

    # Strong ciphers — forward secrecy enabled (ECDHE)
    # Removes: RC4, DES, 3DES, EXPORT, NULL, MD5
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;  # TLS 1.3 selects best cipher from client list

    # Session resumption (performance + security)
    ssl_session_timeout 1d;
    ssl_session_cache shared:MozSSL:10m;
    ssl_session_tickets off;  # Disable — session ticket keys are hard to rotate

    # OCSP Stapling — proves cert is not revoked without client-side OCSP lookup
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/letsencrypt/live/YOUR_DOMAIN/chain.pem;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # DH parameters (generate: openssl dhparam -out /etc/nginx/dhparam.pem 4096)
    ssl_dhparam /etc/nginx/dhparam.pem;

    # ── Security Headers ───────────────────────────────────────────────────────
    # These are set at Nginx level for all responses including errors

    # HSTS: Force HTTPS for 1 year, include subdomains, preload
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Prevent MIME type sniffing
    add_header X-Content-Type-Options "nosniff" always;

    # Certificate Transparency
    add_header Expect-CT "enforce, max-age=86400" always;

    # Remove server version fingerprint
    server_tokens off;

    # ── Request Limits (WAF) ───────────────────────────────────────────────────
    client_max_body_size 1m;              # Hard limit on request body size
    client_header_buffer_size 2k;
    large_client_header_buffers 4 8k;     # Max 8KB per header line
    client_body_timeout 10s;             # Kill slow loris attacks
    client_header_timeout 10s;
    send_timeout 10s;
    keepalive_timeout 65s;

    # ── Rate Limiting (Nginx level — before Express) ───────────────────────────
    # Define rate limit zones in nginx.conf http block:
    #   limit_req_zone $binary_remote_addr zone=api:10m rate=100r/m;
    #   limit_req_zone $binary_remote_addr zone=auth:10m rate=5r/m;
    limit_req zone=api  burst=20  nodelay;
    limit_req zone=auth burst=5   nodelay;

    # Block common scanner paths immediately
    location ~ ^/(\.git|\.env|wp-admin|phpMyAdmin|server-status|\.htaccess) {
        return 403;
    }

    # ── API Proxy ──────────────────────────────────────────────────────────────
    location /api/ {
        proxy_pass         http://xcg_api;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Timeout settings
        proxy_connect_timeout 10s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;

        # Remove server internal headers from responses
        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;
    }

    # Admin routes — extra IP restriction at Nginx level
    # Replace with your actual admin IP(s)
    location /admin/ {
        # Restrict to admin office IPs BEFORE hitting Express
        # Add your admin IPs here:
        # allow 1.2.3.4;       # Office IP
        # deny all;

        proxy_pass         http://xcg_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Health check — internal only (not exposed to public)
    location /internal/health {
        allow 127.0.0.1;
        allow 10.0.0.0/8;    # Internal VPC
        deny all;

        proxy_pass         http://xcg_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
    }

    # Public payment page
    location /api/v1/pay/ {
        proxy_pass         http://xcg_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Everything else → 404
    location / {
        return 404;
    }

    # ── Access Log ─────────────────────────────────────────────────────────────
    access_log /var/log/nginx/xcg_access.log combined;
    error_log  /var/log/nginx/xcg_error.log warn;
}

# ── Add to nginx.conf http block ───────────────────────────────────────────────
# http {
#     limit_req_zone $binary_remote_addr zone=api:10m  rate=100r/m;
#     limit_req_zone $binary_remote_addr zone=auth:10m rate=5r/m;
#     limit_conn_zone $binary_remote_addr zone=conn:10m;
# }
