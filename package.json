{
  "name": "xcoingateway",
  "version": "0.1.0",
  "private": true,
  "description": "Bank-grade crypto payment gateway — USDT TRC20",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=services/api-server",
    "dev:listener": "npm run dev --workspace=services/blockchain-listener",
    "dev:matcher": "npm run dev --workspace=services/matching-engine",
    "dev:withdrawal": "npm run dev --workspace=services/withdrawal-engine",
    "dev:notification": "npm run dev --workspace=services/notification-service",
    "dev:signer": "npm run dev --workspace=services/signing-service",
    "dev:reconciliation": "npm run dev --workspace=services/reconciliation-service",
    "dev:fraud": "npm run dev --workspace=services/fraud-engine",
    "lint": "eslint . --ext .js,.jsx",
    "test": "jest --passWithNoTests",
    "audit:security": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "XCoinGateway",
  "license": "UNLICENSED",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.72.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "otplib": "^13.4.0"
  }
}
