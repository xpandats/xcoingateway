# ============================================================
# XCOINGATEWAY ENVIRONMENT CONFIGURATION
# ============================================================
# COPY this file to .env.local for development
# NEVER commit the actual .env files to git
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# ─── Core ────────────────────────────────────────────────────
NODE_ENV=development
NETWORK_MODE=TESTNET
PORT=3001

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xcoingateway_dev
REDIS_URL=redis://localhost:6379

# ─── Blockchain (Tron Nile Testnet) ──────────────────────────
TRON_NETWORK=testnet
TRONGRID_API_URL=https://nile.trongrid.io
TRONGRID_API_KEY=your_trongrid_api_key_here
TRON_RPC_FALLBACK=https://nile.tronstack.io
# NOTE: USDT contract is HARDCODED in adapter — not from env (security)
TRON_CONFIRMATIONS_REQUIRED=19
TRON_POLL_INTERVAL_MS=4000
TRON_STALE_BLOCK_ALERT_MS=30000

# ─── JWT (ALL must be 64 hex chars, ALL must be unique) ──────
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ──────────────────────────────────────────────
MASTER_ENCRYPTION_KEY=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── HMAC ────────────────────────────────────────────────────
HMAC_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── Queue Message Signing (inter-service auth) ───────────────
# Must be 64 hex chars, must be DIFFERENT from all other secrets
QUEUE_SIGNING_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── Bcrypt ──────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Wallet & Withdrawal ─────────────────────────────────────
HOT_WALLET_MAX_BALANCE=1000
COLD_WALLET_ADDRESS=
WITHDRAWAL_COOLDOWN_MS=3600000
HIGH_VALUE_THRESHOLD=5000
DAILY_WITHDRAWAL_CAP=10000
PER_TX_WITHDRAWAL_LIMIT=1000

# ─── Invoice / Platform Fee ──────────────────────────────────
INVOICE_EXPIRY_MS=900000
PLATFORM_FEE_RATE=0.001

# ─── Payment Page ────────────────────────────────────────────
PAYMENT_PAGE_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AUTH_LOCKOUT_DURATION_MS=900000

# ─── Admin ───────────────────────────────────────────────────
ADMIN_IP_WHITELIST=127.0.0.1,::1
ADMIN_2FA_REQUIRED=true

# ─── Alerts — Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
