# ============================================================
# XCOINGATEWAY ENVIRONMENT CONFIGURATION
# ============================================================
# COPY this file to .env.local for development
# NEVER commit the actual .env files to git
# ============================================================

# --- Core ---
NODE_ENV=development
NETWORK_MODE=TESTNET
PORT=3001

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/xcoingateway_dev
REDIS_URL=redis://localhost:6379

# --- Blockchain (Tron) ---
TRONGRID_API_URL=https://api.shasta.trongrid.io
TRONGRID_API_KEY=your_trongrid_api_key_here
TRON_RPC_FALLBACK=https://api.shasta.trongrid.io
TRON_USDT_CONTRACT=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
TRON_CONFIRMATIONS_REQUIRED=19
TRON_POLL_INTERVAL_MS=5000

# --- JWT ---
JWT_ACCESS_SECRET=CHANGE_ME_random_64_char_string_for_access_tokens
JWT_REFRESH_SECRET=CHANGE_ME_random_64_char_string_for_refresh_tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Encryption ---
MASTER_ENCRYPTION_KEY=CHANGE_ME_random_64_char_hex_string_for_aes256

# --- HMAC ---
HMAC_SECRET=CHANGE_ME_random_64_char_string_for_hmac_signatures
INTERNAL_HMAC_SECRET=CHANGE_ME_random_64_char_string_for_internal_queue_signing

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=12

# --- Wallet ---
HOT_WALLET_MAX_BALANCE=500
COLD_WALLET_ADDRESS=
WITHDRAWAL_COOLDOWN_MS=60000
HIGH_VALUE_THRESHOLD=1000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AUTH_LOCKOUT_DURATION_MS=900000

# --- Webhooks ---
WEBHOOK_RETRY_ATTEMPTS=6
WEBHOOK_TIMEOUT_MS=10000

# --- Admin ---
ADMIN_IP_WHITELIST=127.0.0.1,::1
ADMIN_2FA_REQUIRED=true

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASS=

# --- Invoice ---
INVOICE_EXPIRY_MS=1800000
UNIQUE_AMOUNT_MIN_OFFSET=0.000001
UNIQUE_AMOUNT_MAX_OFFSET=0.009999
