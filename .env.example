# ============================================================
# XCOINGATEWAY ENVIRONMENT CONFIGURATION
# ============================================================
# COPY this file to .env.local for development
# NEVER commit the actual .env files to git
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# ─── Core ────────────────────────────────────────────────────
NODE_ENV=development
NETWORK_MODE=TESTNET
PORT=3001

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xcoingateway_dev

# Mainnet Req #1: Separate audit DB with INSERT-ONLY user
# See packages/database/src/auditConnection.js for MongoDB role setup instructions
# Leave blank in dev to share main connection (with warning)
AUDIT_MONGODB_URI=

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Redis High Availability ─────────────────────────────────
# Mode: standalone (default) | sentinel (recommended prod) | cluster
# See packages/common/src/redisFactory.js for Docker Compose Sentinel example
REDIS_MODE=standalone
# Password (applies to all modes — leave blank for dev)
REDIS_PASSWORD=
# Sentinel: comma-separated host:port pairs (required when REDIS_MODE=sentinel)
REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379
# Sentinel: master group name
REDIS_SENTINEL_NAME=mymaster
# Cluster: comma-separated node:port pairs (required when REDIS_MODE=cluster)
REDIS_CLUSTER_NODES=node1:7000,node2:7001,node3:7002

# ─── Internal Service Auth ───────────────────────────────────
# HMAC-SHA256 shared key for internal service-to-service health/admin calls
# Must be 64 hex chars (32 bytes), must be DIFFERENT from all other secrets
INTERNAL_SERVICE_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── Signing Service ─────────────────────────────────────────
# Global rate limit: max signing operations per second (shared across all replicas)
# Default: 20. Lower in staging to catch rate-limit bugs early.
SIGNING_RATE_LIMIT=20

# ─── Backup (Mainnet Req #5) ──────────────────────────────────
# 64 hex chars (32 bytes) — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# ─── Blockchain (Tron Nile Testnet) ──────────────────────────
TRON_NETWORK=testnet
TRONGRID_API_URL=https://nile.trongrid.io
TRONGRID_API_KEY=your_trongrid_api_key_here
TRON_RPC_FALLBACK=https://nile.tronstack.io
# NOTE: USDT contract is HARDCODED in adapter — not from env (security)
TRON_CONFIRMATIONS_REQUIRED=19
TRON_POLL_INTERVAL_MS=4000
TRON_STALE_BLOCK_ALERT_MS=30000

# ─── JWT (ALL must be 64 hex chars, ALL must be unique) ──────
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ──────────────────────────────────────────────
MASTER_ENCRYPTION_KEY=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── HMAC ────────────────────────────────────────────────────
HMAC_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── Internal HMAC (inter-service authentication) ────────────
# Used by packages/crypto/hmac.js for signing internal service-to-service calls
# Must be 64 hex chars, must be DIFFERENT from HMAC_SECRET
INTERNAL_HMAC_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
# Secret for internal health check endpoint authentication
INTERNAL_CHECK_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex
# CIDR range for internal network validation (middleware/internalAuth.js)
# Docker default bridge: 172.16.0.0/12, Kubernetes: 10.0.0.0/8
INTERNAL_NETWORK_CIDR=127.0.0.1

# ─── Queue Message Signing (inter-service auth) ───────────────
# Must be 64 hex chars, must be DIFFERENT from all other secrets
QUEUE_SIGNING_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ─── Bcrypt ──────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS (production mode only)
# Dev mode allows all origins. Production mode REQUIRES this to be set.
ALLOWED_ORIGINS=https://your-frontend.example.com,https://merchant-portal.example.com

# ─── API Settings ────────────────────────────────────────────
API_VERSION=v1
# Pagination guards (prevent clients requesting unbounded result sets)
PAGINATION_MAX_LIMIT=100
PAGINATION_MAX_PAGE=1000

# ─── Wallet & Withdrawal ─────────────────────────────────────
HOT_WALLET_MAX_BALANCE=1000
COLD_WALLET_ADDRESS=
WITHDRAWAL_COOLDOWN_MS=3600000
HIGH_VALUE_THRESHOLD=5000
DAILY_WITHDRAWAL_CAP=10000
PER_TX_WITHDRAWAL_LIMIT=1000
# Per-merchant withdrawal limit (USDT per day, per merchant)
MERCHANT_WITHDRAWAL_LIMIT=5000

# ─── Invoice / Platform Fee ──────────────────────────────────
INVOICE_EXPIRY_MS=900000
PLATFORM_FEE_RATE=0.001

# ─── Payment Page ────────────────────────────────────────────
PAYMENT_PAGE_URL=http://localhost:3000

# ─── Rate Limiting (Express-level global) ─────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
AUTH_LOCKOUT_DURATION_MS=900000

# ─── IP Rate Limiting (pre-auth, per-IP sliding window) ──────
# These fire BEFORE HMAC auth — blocks volumetric brute-force
# Auth endpoints: strict
IP_LIMIT_AUTH_WINDOW_SEC=300
IP_LIMIT_AUTH_MAX=20
# Merchant API endpoints: moderate
IP_LIMIT_MERCHANT_WINDOW_SEC=60
IP_LIMIT_MERCHANT_MAX=120
# General API endpoints: permissive
IP_LIMIT_GENERAL_WINDOW_SEC=60
IP_LIMIT_GENERAL_MAX=300

# ─── Blockchain Leader Election ──────────────────────────────
# Only one blockchain-listener instance polls TronGrid at a time.
# Leader acquires a Redis SETNX lock with TTL = LEADER_LOCK_TTL_MS.
# If renewed every LEADER_RENEW_MS, no other instance tries to lead.
# Non-leaders retry every LEADER_RETRY_MS.
LEADER_LOCK_TTL_MS=30000
LEADER_RENEW_MS=10000
LEADER_RETRY_MS=15000

# ─── Admin ───────────────────────────────────────────────────
ADMIN_IP_WHITELIST=127.0.0.1,::1
ADMIN_2FA_REQUIRED=true

# ─── Admin Seed (initial admin user — first deploy only) ─────
# Used by: node services/api-server/src/scripts/seedAdmin.js
# ADMIN_SEED_PASSWORD is REQUIRED; all others have defaults.
ADMIN_SEED_EMAIL=admin@xcoingateway.com
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FIRST_NAME=System
ADMIN_SEED_LAST_NAME=Admin

# ─── Alerts — Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
