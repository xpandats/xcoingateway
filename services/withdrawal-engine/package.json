{
  "name": "xcg-withdrawal-engine",
  "version": "1.0.0",
  "description": "XCoinGateway Withdrawal Engine — balance validation, cooling-off, signing requests",
  "main": "src/server.js",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --testEnvironment=node --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --testEnvironment=node --detectOpenHandles --forceExit"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true
  },
  "devDependencies": {
    "jest": "^30.3.0"
  },
  "dependencies": {
    "@xcg/cache": "*",
    "@xcg/common": "*",
    "@xcg/database": "*",
    "@xcg/logger": "*",
    "@xcg/queue": "*",
    "@xcg/tron": "*",
    "dotenv": "^16.0.0",
    "ioredis": "^5.3.0",
    "mongoose": "^7.0.0",
    "uuid": "^9.0.0"
  }
}
