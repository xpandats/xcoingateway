{
  "name": "xcg-notification-service",
  "version": "1.0.0",
  "description": "XCoinGateway Notification Service — HMAC-signed webhooks + Telegram alerts",
  "main": "src/server.js",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --testEnvironment=node --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --testEnvironment=node --detectOpenHandles --forceExit"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true,
    "testTimeout": 10000
  },
  "dependencies": {
    "@xcg/common": "*",
    "@xcg/crypto": "*",
    "@xcg/database": "*",
    "@xcg/logger": "*",
    "@xcg/queue": "*",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.1"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
