{
  "name": "xcg-matching-engine",
  "version": "1.0.0",
  "description": "XCoinGateway Matching Engine — transaction matching, state machine, double-entry ledger",
  "main": "src/server.js",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --testEnvironment=node --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --testEnvironment=node --detectOpenHandles --forceExit"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "uuid": "^9.0.0"
  },
  "dependencies": {
    "@xcg/common": "*",
    "@xcg/database": "*",
    "@xcg/logger": "*",
    "@xcg/queue": "*"
  }
}
