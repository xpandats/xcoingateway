{
  "name": "xcg-signing-service",
  "version": "1.0.0",
  "description": "XCoinGateway Signing Service — Zone 3, queue-only, NO HTTP endpoint",
  "main": "src/server.js",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --testEnvironment=node --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --testEnvironment=node --detectOpenHandles --forceExit"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true
  },
  "devDependencies": {
    "jest": "^30.3.0"
  },
  "dependencies": {
    "@xcg/common": "*",
    "@xcg/crypto": "*",
    "@xcg/database": "*",
    "@xcg/logger": "*",
    "@xcg/queue": "*",
    "@xcg/tron": "*"
  }
}
